{
  "name": "mcp-server-manager",
  "version": "0.2.1",
  "description": "MCP Server Process Manager GUI",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.0.0",
    "npm": "please-use-yarn",
    "pnpm": "please-use-yarn"
  },
  "scripts": {
    "dev": "concurrently -k -r \"yarn run dev:main\" \"yarn run dev:renderer\" \"yarn run dev:electron\"",
    "dev:main": "tsc -w -p tsconfig.main.json",
    "dev:renderer": "vite",
    "dev:electron": "wait-on dist/main/index.js http://localhost:3001 && electron . --dev",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron .",
    "format": "prettier --write \"src/**/*.{ts,js,css,json}\"",
    "lint": "tsc --noEmit",
    "dist:win": "yarn build && electron-builder --win --publish=never",
    "dist:mac": "yarn build && electron-builder --mac --publish=never",
    "dist:linux": "yarn build && electron-builder --linux --publish=never",
    "release:win": "yarn build && electron-builder --win --publish=always",
    "release:mac": "yarn build && electron-builder --mac --publish=always",
    "release:linux": "yarn build && electron-builder --linux --publish=always",
    "clean": "rimraf dist release node_modules/.cache"
  },
  "keywords": [
    "mcp",
    "server",
    "process",
    "manager"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.6",
    "@types/express-http-proxy": "^1.6.7",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "archiver": "^7.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.9.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@ngrok/ngrok": "^1.7.0",
    "electron-updater": "^6.8.4",
    "express": "^5.2.1",
    "express-http-proxy": "^2.1.2",
    "i18next": "^26.0.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.14.2",
    "selfsigned": "^5.5.0",
    "zustand": "^5.0.12"
  }
}
